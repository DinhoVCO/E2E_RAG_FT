# Hugging Face Hub token (https://huggingface.co/settings/tokens)
HF_TOKEN=
# Optional: default Hub org for model uploads (default: DinoStackAI)
HF_ORG=DinoStackAI
HF_USERNAME=

# Email for NCBI E-utilities (recommended when fetching PubMed abstracts)
NCBI_EMAIL=

# Weights & Biases (https://wandb.ai/settings)
WANDB_API_KEY=
WANDB_PROJECT=qwen3-embedding-finetuning
WANDB_PROJECT_STEP2=qwen3-generative-finetuning-v2
